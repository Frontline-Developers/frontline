rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
            'category', 'description', 'locationLabel', 'location', 'geohash',
            'mediaUrls', 'createdAt', 'userId', 'status', 'confirmCount',
            'disputeCount', 'isDisputed', 'exifStripped', 'tokenHash'
          ])
        && request.resource.data.keys().hasOnly([
            'category', 'description', 'locationLabel', 'location', 'geohash',
            'mediaUrls', 'createdAt', 'userId', 'status', 'confirmCount',
            'disputeCount', 'isDisputed', 'exifStripped', 'tokenHash'
          ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmCount == 0
        && request.resource.data.disputeCount == 0
        && request.resource.data.isDisputed == false
        && request.resource.data.category in ['combat', 'aid', 'alert', 'displaced', 'infra', 'other']
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000;

      // Feed is intentionally public — any signed-in user can list/query reports.
      allow list: if request.auth != null;

      // Any authenticated user may get a report by ID. The list rule already
      // exposes all fields via queries, so this adds no new attack surface.
      // Required for Firestore transactions (tx.get) to work for non-owners
      // e.g. casting votes on reports you did not submit.
      allow get: if request.auth != null;

      // Vote transactions touch confirmCount/disputeCount/isDisputed.
      // addComment batch increments commentCount.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['confirmCount', 'disputeCount', 'isDisputed', 'commentCount']);

      // Owner soft-delete: sets status='deleted' and removes tokenHash.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'tokenHash'])
        && request.resource.data.status == 'deleted';

      // Per-user interaction record — owner can create, update, or delete their own doc.
      match /interactions/{userId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['type', 'token', 'createdAt'])
          && request.resource.data.type in ['confirm', 'dispute'];
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(
               ['type', 'text', 'authorToken', 'createdAt', 'upvotes', 'downvotes'])
          && request.resource.data.keys().hasOnly(
               ['type', 'text', 'authorToken', 'createdAt', 'upvotes', 'downvotes', 'parentCommentId'])
          && request.resource.data.type in ['confirm', 'dispute', 'context']
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.upvotes == 0
          && request.resource.data.downvotes == 0
          && (!request.resource.data.keys().hasAny(['parentCommentId'])
              || request.resource.data.parentCommentId is string);

        // Vote transactions may touch upvotes or downvotes counters.
        allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['upvotes', 'downvotes']);

        // Per-user upvote record.
        match /upvoters/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == userId;
        }

        // Per-user downvote record.
        match /downvoters/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    match /wire_news/{articleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Alert subscriptions — owner can manage their own subscriptions.
    match /user_alerts/{userId}/subscriptions/{subId} {
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
            'userId', 'locationLabel', 'lat', 'lng', 'radiusKm', 'categories', 'createdAt'
          ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.radiusKm is number
        && request.resource.data.radiusKm >= 1
        && request.resource.data.radiusKm <= 20
        && request.resource.data.categories is list
        && request.resource.data.categories.size() > 0;
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // FCM device tokens — owner write-only; admin SDK reads server-side.
    match /user_tokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
