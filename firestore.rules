rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reports — anonymous users can create; owner can read their own
    // TODO: flesh out rules once schema is finalized
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'category', 'description', 'location', 'geohash', 'mediaUrls',
          'createdAt', 'userId', 'status', 'confirmCount', 'disputeCount',
          'isDisputed', 'exifStripped'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmCount == 0
        && request.resource.data.disputeCount == 0
        && request.resource.data.isDisputed == false;

      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Wire news — read-only for authenticated users; writes are CF-only
    match /wire_news/{articleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
