rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
            'category', 'description', 'location', 'geohash', 'mediaUrls',
            'createdAt', 'userId', 'status', 'confirmCount', 'disputeCount',
            'isDisputed', 'exifStripped'
          ])
        && request.resource.data.keys().hasOnly([
            'category', 'description', 'location', 'geohash', 'mediaUrls',
            'createdAt', 'userId', 'status', 'confirmCount', 'disputeCount',
            'isDisputed', 'exifStripped'
          ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmCount == 0
        && request.resource.data.disputeCount == 0
        && request.resource.data.isDisputed == false
        && request.resource.data.category in ['combat', 'aid', 'alert', 'displaced', 'infra', 'other']
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000;

      // Feed is intentionally public — any signed-in user can list/query reports.
      allow list: if request.auth != null;

      // Individual document get is restricted to the owner. The compare screen
      // reads another user's report via a list query (FieldPath.documentId filter)
      // which falls under the list rule above, not this get rule.
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;

      // Vote transactions only touch confirmCount, disputeCount, isDisputed.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['confirmCount', 'disputeCount', 'isDisputed']);

      // Per-user interaction record — owner can create, update, or delete their own doc.
      match /interactions/{userId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['type', 'token', 'createdAt'])
          && request.resource.data.type in ['confirm', 'dispute'];
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(
               ['type', 'text', 'authorToken', 'createdAt', 'upvotes'])
          && request.resource.data.type in ['confirm', 'dispute', 'context']
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.upvotes == 0;

        // Only the upvote transaction may touch the upvotes counter.
        allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['upvotes']);

        // Per-user upvote record — create once (idempotency enforced in client transaction).
        match /upvoters/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    match /wire_news/{articleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
