rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Deny all by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Report media — authenticated users can upload to their own path
    // TODO: add file size and content-type restrictions
    match /reports/{userId}/{reportId}/{fileName} {
      allow write: if request.auth != null
        && request.auth.uid == userId;
      // Any signed-in user can read report media — reports are public in the feed.
      allow read: if request.auth != null;
    }
  }
}
